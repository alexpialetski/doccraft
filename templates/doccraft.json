{
  "$schema": "https://cdn.jsdelivr.net/npm/doccraft@{{DOCCRAFT_VERSION}}/schema/doccraft.schema.json",
  "version": "{{DOCCRAFT_VERSION}}",
  "_hint": "Edit with the doccraft-config skill (npx doccraft@latest llm exposes the schema).",
  "docsDir": "docs",
  "story": {
    "areas": ["api", "cli", "auth", "data", "infra", "schemas"],
    "slices": ["ui", "admin", "onboarding"],
    "themes": ["observability", "performance", "security", "docs", "testing"],
    "id": {
      "tiers": ["p0", "p1", "p2", "p3", "p4"],
      "pattern": "^(P\\d+(\\.\\d+)?|[a-z][a-z0-9-]+)$"
    }
  },
  "queue": {
    "tables": {
      "suggestedOrder": "Suggested order",
      "platformSpikes": "Platform spikes"
    }
  },
  "queueAudit": {
    "laneFrom": ["area", "slice"],
    "scale": {
      "maxStoryFiles": 5,
      "maxQueueReorderPct": 50
    }
  },
  "sessionWrap": {
    "capture": {
      "research": true,
      "reference": true,
      "business": false
    }
  }
}
